# Nano Banana (Gemini image generation) API key — https://aistudio.google.com/apikey
# (GEMINI_API_KEY works as a fallback name; one key powers TTS + generation + editing)
NANO_BANANA_API_KEY=

# Stock photo providers for fetch_stock.py (b-roll), tried in this order.
# Pexels — free key: https://www.pexels.com/api/  (no attribution required)
PEXELS_API_KEY=
# Unsplash — free key: https://unsplash.com/developers  (no attribution required)
UNSPLASH_ACCESS_KEY=
# (Openverse is the keyless fallback — CC pool; CC-BY results require a caption credit)

# Optional overrides
NANO_BANANA_MODEL=gemini-2.5-flash-image
EDGE_TTS_VOICE=en-US-AndrewNeural
