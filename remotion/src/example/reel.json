    {
      "type": "HookCard",
      "duration": 2.5,
      "text": "Claude just got a *massive upgrade*",
      "voiceSegment": "Claude just got a massive upgrade."
    },
    {
      "type": "TerminalScene",
      "duration": 6,
      "text": "try it",
      "terminal": [
        {"kind": "command", "text": "pip install anthropic"},
        {"kind": "output", "text": "Successfully installed anthropic"},
        {"kind": "command", "text": "python chat.py --model claude-fable-5"},
        {"kind": "success", "text": "✓ connected"}
      ],
      "voiceSegment": "And you can try it with two commands."
    },
    {
      "type": "ChartScene",
      "duration": 5,
      "text": "SWE-bench verified",
      "label": "Source: model card",
      "chart": [
        {"label": "Fable 5", "value": 82.1, "suffix": "%", "highlight": true},
        {"label": "Opus 4.5", "value": 74.5, "suffix": "%"},
        {"label": "GPT-5.2", "value": 71.3, "suffix": "%"}
      ],
      "voiceSegment": "It tops the coding benchmark by a wide margin."
    },
    {
      "type": "ImageScene",
      "duration": 4,
      "kenBurns": "zoom-in",
      "text": "Fable 5 tops every benchmark",
      "imagePrompt": "futuristic AI model visualization, glowing neural core",
      "voiceSegment": "The new Fable 5 model tops every major benchmark the industry uses."
    },
    {
      "type": "StatCallout",
      "duration": 3,
      "stat": "2x",
      "label": "faster reasoning",
      "voiceSegment": "It reasons twice as fast as the previous generation."
    },
    {
      "type": "SplitCompare",
      "duration": 4,
      "text": "Old vs new",
      "leftTitle": "Opus 4.5",
      "leftText": "Previous flagship",
      "rightTitle": "Fable 5",
      "rightText": "New state of the art",
      "voiceSegment": "Compared to the old flagship, it is simply a different class of model."
    },
    {
      "type": "OutroCard",
      "duration": 2.5,
      "text": "Follow for daily AI news"
    }
  ]
}
